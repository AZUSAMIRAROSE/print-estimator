PORT=4000
NODE_ENV=development
JWT_SECRET=change_this_to_a_long_random_secret_min_48_chars
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:1420
DB_PATH=./server/data/app.db
UPLOAD_DIR=./server/uploads
ALLOW_ANONYMOUS_API=true

# SMTP (optional — simulated if not set)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@print-estimator.local

# Stripe (optional — simulated if not set)
STRIPE_SECRET_KEY=
